#!/bin/sh
# Force the Boykisser wallpaper onto every monitor XFCE actually has.
# Real (and live/VM) outputs are named per connector (eDP-1, HDMI-A-1, DP-1,
# Virtual-1...) and never match a shipped xfce4-desktop.xml, so a freshly
# started xfdesktop gives them empty backdrops -> grey desktop. We set them
# live, after xfdesktop is up, and keep retrying for a while because in the live
# session the desktop can take a few seconds to appear.

WALL="/usr/share/backgrounds/boykisser/boykisser1.png"
[ -f "$WALL" ] || WALL="/usr/share/backgrounds/boykisser/boykisser2.png"
[ -f "$WALL" ] || exit 0

CHAN="xfce4-desktop"

# Create-or-set a string/int/bool property (xfconf needs -n the first time).
set_str()  { xfconf-query -c "$CHAN" -p "$1" -s "$2" 2>/dev/null || xfconf-query -c "$CHAN" -p "$1" -n -t string -s "$2" 2>/dev/null; }
set_int()  { xfconf-query -c "$CHAN" -p "$1" -s "$2" 2>/dev/null || xfconf-query -c "$CHAN" -p "$1" -n -t int    -s "$2" 2>/dev/null; }
set_bool() { xfconf-query -c "$CHAN" -p "$1" -s "$2" 2>/dev/null || xfconf-query -c "$CHAN" -p "$1" -n -t bool   -s "$2" 2>/dev/null; }

stamp() {
	base="$1"
	set_str  "$base/last-image" "$WALL"
	set_str  "$base/image-path" "$WALL"   # older xfdesktop key
	set_int  "$base/image-style" 5        # 5 = zoomed/scaled
	set_bool "$base/image-show" true
	set_int  "$base/color-style" 0
}

apply() {
	# 1) Update every backdrop xfconf already knows about.
	xfconf-query -c "$CHAN" -l 2>/dev/null | grep -E '/(last-image|image-path)$' | while read -r prop; do
		xfconf-query -c "$CHAN" -p "$prop" -s "$WALL" 2>/dev/null
	done

	# 2) Seed a full backdrop for every connected output (covers fresh monitors).
	if command -v xrandr >/dev/null 2>&1; then
		for mon in $(xrandr 2>/dev/null | awk '/ connected/{print $1}'); do
			stamp "/backdrop/screen0/monitor$mon/workspace0"
		done
	fi

	# 3) Generic fallbacks that almost always exist somewhere.
	stamp "/backdrop/screen0/monitor0/workspace0"
	stamp "/backdrop/screen0/monitorVirtual-1/workspace0"

	xfdesktop --reload >/dev/null 2>&1 || true
}

set_bool /backdrop/single-workspace-mode true

# Retry for ~60s so we win even if xfdesktop / xfconfd start late in the live
# session, then stop once things have settled.
n=0
while [ "$n" -lt 30 ]; do
	apply
	n=$((n + 1))
	sleep 2
done
