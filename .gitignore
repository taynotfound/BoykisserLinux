# live-build artifacts
*.iso
*.img
*.log
.build/
cache/
chroot/
chroot.files
chroot.packages.*
binary/
binary.*
live-image-*.files
live-image-*.packages
live-image-*.contents
source/
source.*
.stage/
config/binary
config/bootstrap
config/chroot
config/common
config/source
config/package-lists/*.binary
# live-build's root-level artifact dir only — anchored so it does NOT swallow
# config/includes.chroot/usr/local/ (where the boykisser-* helper scripts live).
/local/
*.ovmf-vars.fd
website/
# netinstall build marker (created/removed by build.sh --netinstall)
config/includes.chroot/etc/boykisser/netinstall
config/package-lists/*.disabled
